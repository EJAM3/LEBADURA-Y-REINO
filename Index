<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Donde Dios entra, todo cambia · Bosquejo de predicación</title>
<style>
:root {
  --bg: #f5f1e8;
  --bg-card: #fbf7ee;
  --bg-soft: #efe9dc;
  --text: #3d3528;
  --text-soft: #6b5f4c;
  --text-muted: #8a7e6a;
  --accent: #7a6a4f;
  --accent-soft: #b8a67f;
  --border: #d9cfb8;
  --verse: #5a4a2e;
  --verse-bg: #f0e7d0;
  --shadow: 0 1px 3px rgba(61, 53, 40, 0.06);
  --radius: 10px;
  --font-body: Georgia, 'Cambria', 'Times New Roman', serif;
  --font-ui: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  --fs-base: 18px;
}

body.dark {
  --bg: #1e1b17;
  --bg-card: #25221c;
  --bg-soft: #2b2720;
  --text: #e8dfc9;
  --text-soft: #c4b896;
  --text-muted: #9a8e73;
  --accent: #c9b98e;
  --accent-soft: #8a7a55;
  --border: #3a342b;
  --verse: #e0d3a8;
  --verse-bg: #2f2a20;
  --shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
}

* { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-size: var(--fs-base);
  line-height: 1.75;
  transition: background 0.3s ease, color 0.3s ease;
}

.toolbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  padding: 10px 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  font-family: var(--font-ui);
  font-size: 13px;
  box-shadow: var(--shadow);
}

.tool-group {
  display: flex;
  gap: 4px;
  align-items: center;
  padding: 0 8px;
  border-right: 1px solid var(--border);
}
.tool-group:last-child { border-right: none; }

.tool-btn {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text);
  padding: 6px 10px;
  border-radius: 6px;
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: 13px;
  transition: all 0.15s;
  display: inline-flex;
  align-items: center;
  gap: 5px;
}
.tool-btn:hover {
  background: var(--bg-soft);
  border-color: var(--accent-soft);
}
.tool-btn.active {
  background: var(--accent-soft);
  color: var(--bg-card);
  border-color: var(--accent);
}
.tool-btn.danger { color: #a64a3e; }
body.dark .tool-btn.danger { color: #d4806f; }

.tool-label {
  color: var(--text-soft);
  font-size: 12px;
  margin-right: 4px;
}

.timer-display {
  font-family: 'Courier New', monospace;
  font-size: 16px;
  font-weight: bold;
  color: var(--accent);
  padding: 4px 10px;
  background: var(--bg-soft);
  border-radius: 6px;
  min-width: 70px;
  text-align: center;
}
.timer-display.warn { color: #c87a3a; }
.timer-display.over { color: #a64a3e; }

.tabs {
  display: flex;
  gap: 2px;
  background: var(--bg-card);
  padding: 0 16px;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 55px;
  z-index: 90;
}
.tab {
  padding: 10px 20px;
  background: transparent;
  border: none;
  color: var(--text-soft);
  cursor: pointer;
  font-family: var(--font-ui);
  font-size: 14px;
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
}
.tab:hover { color: var(--text); }
.tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  font-weight: 500;
}

.view {
  display: none;
  padding: 40px 24px;
  max-width: 780px;
  margin: 0 auto;
}
.view.active { display: block; }

/* BOSQUEJO */
.good-news {
  background: var(--verse-bg);
  border-left: 3px solid var(--accent-soft);
  padding: 20px 24px;
  margin-bottom: 32px;
  border-radius: var(--radius);
}
.good-news h2 {
  margin: 0 0 12px;
  font-size: 1.1em;
  color: var(--accent);
  font-family: var(--font-ui);
  letter-spacing: 0.5px;
  text-transform: uppercase;
  font-weight: 500;
}
.good-news .verse {
  font-style: italic;
  color: var(--verse);
  margin: 0 0 12px;
  line-height: 1.7;
}
.good-news p {
  margin: 0;
  color: var(--text-soft);
  font-size: 0.95em;
}

h1.title {
  font-size: 2.1em;
  margin: 0 0 8px;
  color: var(--text);
  line-height: 1.25;
  font-weight: 400;
}
.subtitle {
  color: var(--text-soft);
  margin: 0 0 40px;
  font-style: italic;
  font-size: 0.95em;
}

.base-text {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 16px 20px;
  border-radius: var(--radius);
  margin-bottom: 40px;
  font-style: italic;
  color: var(--verse);
}

.section {
  margin-bottom: 36px;
  padding: 4px 0;
}
.section h2 {
  font-family: var(--font-ui);
  font-size: 1.15em;
  color: var(--accent);
  margin: 0 0 14px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
  font-weight: 500;
}
.section ul {
  margin: 0;
  padding-left: 22px;
}
.section li {
  margin-bottom: 10px;
  line-height: 1.7;
}
.verse-inline {
  color: var(--verse);
  font-style: italic;
  display: block;
  margin-top: 4px;
  padding-left: 12px;
  border-left: 2px solid var(--accent-soft);
}

.amen {
  text-align: center;
  margin: 48px 0;
  font-size: 1.3em;
  color: var(--accent);
  font-style: italic;
  letter-spacing: 2px;
}

.notes-area {
  margin-top: 48px;
  padding-top: 24px;
  border-top: 1px dashed var(--border);
}
.notes-area h3 {
  font-family: var(--font-ui);
  color: var(--text-soft);
  font-size: 0.9em;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 500;
}
.notes-area textarea {
  width: 100%;
  min-height: 140px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px;
  font-family: var(--font-body);
  font-size: 0.95em;
  color: var(--text);
  resize: vertical;
  line-height: 1.6;
}
.notes-area textarea:focus {
  outline: none;
  border-color: var(--accent-soft);
}

/* SLIDES VIEW */
.slides-intro {
  color: var(--text-soft);
  margin-bottom: 24px;
  font-style: italic;
  font-size: 0.95em;
}
.slide {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px 32px;
  margin-bottom: 16px;
  position: relative;
  min-height: 140px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-shadow: var(--shadow);
}
.slide-number {
  position: absolute;
  top: 10px;
  right: 14px;
  font-family: var(--font-ui);
  font-size: 11px;
  color: var(--text-muted);
  letter-spacing: 1px;
}
.slide-title {
  font-size: 1.5em;
  color: var(--accent);
  margin: 0 0 10px;
  font-weight: 400;
}
.slide-body {
  margin: 0;
  color: var(--text);
  font-size: 1.05em;
  line-height: 1.6;
}
.slide-verse {
  font-style: italic;
  color: var(--verse);
  font-size: 0.95em;
  margin-top: 8px;
}
.slide-cover .slide-title { font-size: 2em; text-align: center; }
.slide-cover { text-align: center; padding: 50px 32px; }

.speaking.active {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

/* TIMER MODAL */
.timer-modal {
  display: none;
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  justify-content: center;
  align-items: center;
}
.timer-modal.show { display: flex; }
.timer-modal-content {
  background: var(--bg-card);
  padding: 28px 32px;
  border-radius: var(--radius);
  min-width: 280px;
  font-family: var(--font-ui);
}
.timer-modal h3 {
  margin: 0 0 16px;
  color: var(--accent);
  font-weight: 500;
}
.timer-modal label {
  display: block;
  margin-bottom: 12px;
  color: var(--text-soft);
  font-size: 14px;
}
.timer-modal input {
  width: 80px;
  padding: 6px 10px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg);
  color: var(--text);
  font-family: inherit;
  margin-left: 8px;
}
.timer-modal-actions {
  display: flex;
  gap: 8px;
  justify-content: flex-end;
  margin-top: 16px;
}

/* IMPRESIÓN */
@media print {
  .toolbar, .tabs, .notes-area, .timer-modal { display: none !important; }
  body { background: white; color: black; }
  .view { display: block !important; padding: 20px; }
  .view#vista-slides { page-break-before: always; }
  .slide { page-break-inside: avoid; break-inside: avoid; }
}

/* RESPONSIVE */
@media (max-width: 600px) {
  .toolbar { font-size: 12px; padding: 8px; }
  .tool-btn { padding: 5px 8px; font-size: 12px; }
  .tool-label { display: none; }
  .view { padding: 24px 16px; }
  h1.title { font-size: 1.6em; }
  .tabs { top: 65px; }
}
</style>
</head>
