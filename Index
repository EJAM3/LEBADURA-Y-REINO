<script>
// ============ TABS ============
const tabs = document.querySelectorAll('.tab');
const views = document.querySelectorAll('.view');
tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => t.classList.remove('active'));
    views.forEach(v => v.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById(tab.dataset.view).classList.add('active');
    window.scrollTo(0, 0);
  });
});

// ============ TEMA CLARO/OSCURO ============
const btnTheme = document.getElementById('btn-theme');
function applyTheme(isDark) {
  document.body.classList.toggle('dark', isDark);
  btnTheme.textContent = isDark ? '☀ Claro' : '☾ Oscuro';
  try { localStorage.setItem('tema', isDark ? 'dark' : 'light'); } catch(e){}
}
btnTheme.addEventListener('click', () => applyTheme(!document.body.classList.contains('dark')));
try {
  const saved = localStorage.getItem('tema');
  if (saved === 'dark') applyTheme(true);
  else if (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches) applyTheme(true);
} catch(e){}

// ============ TAMAÑO DE TEXTO ============
let currentSize = 18;
try {
  const savedSize = parseInt(localStorage.getItem('fs'), 10);
  if (savedSize >= 12 && savedSize <= 36) currentSize = savedSize;
} catch(e){}
function applySize(size) {
  currentSize = Math.max(12, Math.min(36, size));
  document.documentElement.style.setProperty('--fs-base', currentSize + 'px');
  document.body.style.fontSize = currentSize + 'px';
  try { localStorage.setItem('fs', currentSize); } catch(e){}
}
applySize(currentSize);
document.getElementById('btn-plus').addEventListener('click', () => applySize(currentSize + 2));
document.getElementById('btn-minus').addEventListener('click', () => applySize(currentSize - 2));
document.getElementById('btn-reset').addEventListener('click', () => applySize(18));

// ============ LECTOR DE VOZ ============
const btnSpeak = document.getElementById('btn-speak');
const btnPause = document.getElementById('btn-pause');
const btnStop = document.getElementById('btn-stop');
let utterance = null;
let speaking = false;

function getTextToSpeak() {
  const activeView = document.querySelector('.view.active');
  if (!activeView) return '';
  // Quitar las notas del área de texto para no leerlas
  const clone = activeView.cloneNode(true);
  const notas = clone.querySelector('.notes-area');
  if (notas) notas.remove();
  return clone.innerText.replace(/\s+/g, ' ').trim();
}

btnSpeak.addEventListener('click', () => {
  if (!('speechSynthesis' in window)) {
    alert('Tu navegador no soporta lectura de voz.');
    return;
  }
  window.speechSynthesis.cancel();
  utterance = new SpeechSynthesisUtterance(getTextToSpeak());
  utterance.lang = 'es-ES';
  utterance.rate = 0.95;
  utterance.pitch = 1;

  // Intentar elegir una voz en español
  const voices = window.speechSynthesis.getVoices();
  const esVoice = voices.find(v => v.lang.startsWith('es'));
  if (esVoice) utterance.voice = esVoice;

  utterance.onstart = () => { speaking = true; btnSpeak.classList.add('active'); };
  utterance.onend = () => { speaking = false; btnSpeak.classList.remove('active'); };
  utterance.onerror = () => { speaking = false; btnSpeak.classList.remove('active'); };
  window.speechSynthesis.speak(utterance);
});

btnPause.addEventListener('click', () => {
  if (!('speechSynthesis' in window)) return;
  if (window.speechSynthesis.paused) window.speechSynthesis.resume();
  else if (window.speechSynthesis.speaking) window.speechSynthesis.pause();
});

btnStop.addEventListener('click', () => {
  if (!('speechSynthesis' in window)) return;
  window.speechSynthesis.cancel();
  speaking = false;
  btnSpeak.classList.remove('active');
});

// Forzar carga de voces
if ('speechSynthesis' in window) {
  window.speechSynthesis.getVoices();
  window.speechSynthesis.onvoiceschanged = () => window.speechSynthesis.getVoices();
}

// ============ CRONÓMETRO ============
let timerSeconds = 0;
let timerRunning = false;
let timerInterval = null;
let targetMinutes = 30;
let warnMinutes = 25;

try {
  const t = parseInt(localStorage.getItem('targetMin'), 10);
  const w = parseInt(localStorage.getItem('warnMin'), 10);
  if (t) targetMinutes = t;
  if (w) warnMinutes = w;
} catch(e){}

const timerDisplay = document.getElementById('timer-display');
function updateTimerDisplay() {
  const m = Math.floor(timerSeconds / 60).toString().padStart(2, '0');
  const s = (timerSeconds % 60).toString().padStart(2, '0');
  timerDisplay.textContent = m + ':' + s;
  timerDisplay.classList.remove('warn', 'over');
  if (timerSeconds >= targetMinutes * 60) timerDisplay.classList.add('over');
  else if (timerSeconds >= warnMinutes * 60) timerDisplay.classList.add('warn');
}

document.getElementById('btn-timer-start').addEventListener('click', () => {
  if (timerRunning) return;
  timerRunning = true;
  timerInterval = setInterval(() => {
    timerSeconds++;
    updateTimerDisplay();
  }, 1000);
});

document.getElementById('btn-timer-pause').addEventListener('click', () => {
  timerRunning = false;
  clearInterval(timerInterval);
});

document.getElementById('btn-timer-reset').addEventListener('click', () => {
  timerRunning = false;
  clearInterval(timerInterval);
  timerSeconds = 0;
  updateTimerDisplay();
});

document.getElementById('btn-timer-config').addEventListener('click', () => {
  document.getElementById('target-minutes').value = targetMinutes;
  document.getElementById('warn-minutes').value = warnMinutes;
  document.getElementById('timer-modal').classList.add('show');
});

document.getElementById('btn-timer-cancel').addEventListener('click', () => {
  document.getElementById('timer-modal').classList.remove('show');
});

document.getElementById('btn-timer-save').addEventListener('click', () => {
  const t = parseInt(document.getElementById('target-minutes').value, 10);
  const w = parseInt(document.getElementById('warn-minutes').value, 10);
  if (t > 0) targetMinutes = t;
  if (w > 0) warnMinutes = w;
  try {
    localStorage.setItem('targetMin', targetMinutes);
    localStorage.setItem('warnMin', warnMinutes);
  } catch(e){}
  document.getElementById('timer-modal').classList.remove('show');
  updateTimerDisplay();
});

updateTimerDisplay();

// ============ IMPRIMIR + FULLSCREEN ============
document.getElementById('btn-print').addEventListener('click', () => window.print());
document.getElementById('btn-fullscreen').addEventListener('click', () => {
  if (!document.fullscreenElement) document.documentElement.requestFullscreen();
  else document.exitFullscreen();
});

// ============ NOTAS PERSISTENTES ============
const notasEl = document.getElementById('notas');
try {
  const saved = localStorage.getItem('notas');
  if (saved) notasEl.value = saved;
} catch(e){}
notasEl.addEventListener('input', () => {
  try { localStorage.setItem('notas', notasEl.value); } catch(e){}
});

// ============ ATAJOS DE TECLADO ============
document.addEventListener('keydown', (e) => {
  // Ctrl/Cmd + Plus / Minus / 0
  if ((e.ctrlKey || e.metaKey) && (e.key === '+' || e.key === '=')) {
    e.preventDefault();
    applySize(currentSize + 2);
  } else if ((e.ctrlKey || e.metaKey) && e.key === '-') {
    e.preventDefault();
    applySize(currentSize - 2);
  } else if ((e.ctrlKey || e.metaKey) && e.key === '0') {
    e.preventDefault();
    applySize(18);
  }
  // Alt + T : tema
  else if (e.altKey && e.key.toLowerCase() === 't') {
    e.preventDefault();
    applyTheme(!document.body.classList.contains('dark'));
  }
  // Alt + L : leer
  else if (e.altKey && e.key.toLowerCase() === 'l') {
    e.preventDefault();
    btnSpeak.click();
  }
  // Alt + S : iniciar cronómetro
  else if (e.altKey && e.key.toLowerCase() === 's') {
    e.preventDefault();
    document.getElementById('btn-timer-start').click();
  }
  // Esc cierra modal
  else if (e.key === 'Escape') {
    document.getElementById('timer-modal').classList.remove('show');
  }
});
</script>
</body>
</html>
